<Window
    x:Class="WarehouseSystem.Views.MainWindowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WarehouseSystem.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindowView"
    Width="800"
    Height="600"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="100"
                    Content="当前用户:"
                    FontSize="20" />
                <TextBlock
                    Width="200"
                    FontSize="20"
                    Text="{Binding UserName}" />
                <Button
                    Width="100"
                    Height="40"
                    Command="{Binding LoginCommand}"
                    Content="登录" />
                <Button
                    Width="100"
                    Height="40"
                    Command="{Binding LogoutAsyncCommand}"
                    Content="登出" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Width="40"
                        Height="35"
                        Margin="0,0,20,0"
                        Command="{Binding GotoProductCommand}"
                        Content="商品" />
                    <Button
                        Width="40"
                        Height="35"
                        Margin="0,0,20,0"
                        Command="{Binding GotoInventoryCommand}"
                        Content="仓库" />
                    <Button
                        Width="40"
                        Height="35"
                        Margin="0,0,20,0"
                        Command="{Binding GotoLogViewerCommand}"
                        Content="库存" />
                    <Button
                        Width="40"
                        Height="35"
                        Margin="0,0,20,0"
                        Command="{Binding GotoWarehouseCommand}"
                        Content="日志" />
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="10,10,10,0">
                <ContentControl Content="{Binding MyContentControl}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
